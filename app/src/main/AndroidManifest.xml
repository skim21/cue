<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- CLIPBOARD_SERVICE 는 시스템 서비스로 별도 permission 불필요, 명시적 선언 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".CueApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Cue">

        <!-- 메인 런처 액티비티 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Import 액티비티: 카카오톡 대화 내보내기 .txt 공유 수신 -->
        <activity
            android:name=".share.ImportActivity"
            android:exported="true"
            android:label="Cue로 분석하기"
            android:theme="@style/Theme.Cue">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <!-- ProcessText 액티비티: 텍스트 선택 시 공유 시트에 노출 -->
        <activity
            android:name=".processtext.ProcessTextActivity"
            android:exported="true"
            android:label="@string/process_text_label"
            android:theme="@style/Theme.Cue.Transparent">
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

    </application>

</manifest>
